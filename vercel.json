{
  "redirects": [
    { "source": "/:path*", "has": [{ "type": "host", "value": "www.thegridnexus.com" }], "destination": "https://thegridnexus.com/:path*", "statusCode": 301 },
    { "source": "/billing", "destination": "/subscription/management", "statusCode": 301 },
    { "source": "/settings", "destination": "/subscription/management", "statusCode": 301 },
    { "source": "/nexus/nexusguard", "destination": "/tools/nexusguard", "statusCode": 301 },
    { "source": "/nexus/nexuspath", "destination": "/learn/nexus-path", "statusCode": 301 },
    { "source": "/nexus/nexuspulse", "destination": "/pulse/nexus-pulse", "statusCode": 301 },
    { "source": "/blog-series", "destination": "/blog", "statusCode": 301 },
    { "source": "/articles", "destination": "/blog", "statusCode": 301 },
    { "source": "/live", "destination": "/live-updates", "statusCode": 301 },
    { "source": "/ai", "destination": "/ai-pulse", "statusCode": 301 },
    { "source": "/cybersecurity", "destination": "/security", "statusCode": 301 },
    { "source": "/cyber", "destination": "/security", "statusCode": 301 },
    { "source": "/gamming", "destination": "/gaming", "statusCode": 301 },
    { "source": "/security-tools", "destination": "/tools/security-scanner", "statusCode": 301 },
    { "source": "/p/:slug", "destination": "/article/:slug", "statusCode": 301 },
    { "source": "/post/:slug", "destination": "/article/:slug", "statusCode": 301 },
    { "source": "/posts/:slug", "destination": "/article/:slug", "statusCode": 301 },
    { "source": "/join", "destination": "/signup", "statusCode": 301 }
  ],
  "headers": [
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/sitemap-index.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/sitemap-articles.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/sitemap-news.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
