# The Grid Nexus - Environment Variables (Single Source of Truth)
# Copy to .env or .env.local and fill in values.
# See docs/deployment.md for production setup.

# ════════════════════════════════════════════════════════════════════════════
# APPLICATION
# ════════════════════════════════════════════════════════════════════════════
VITE_APP_URL=https://thegridnexus.com
NODE_ENV=production

# ════════════════════════════════════════════════════════════════════════════
# DATABASE (Convex - Primary)
# ════════════════════════════════════════════════════════════════════════════
# Convex Deployment URL (REQUIRED for content, articles, news feed)
# Get from: https://dashboard.convex.dev → Project → Settings → Deployment URL
VITE_CONVEX_URL=https://intent-akita-728.convex.cloud

# Convex Deploy Key (REQUIRED for `npx convex deploy`; set in CI/hosting)
# Get from: https://dashboard.convex.dev → Settings → Deploy Keys
CONVEX_DEPLOY_KEY=dev:intent-akita-728|eyJ2MiI6IjYzZjcxNzE0ZjI0MjQ3NzU5NmNhZDZhOTgwMGI1Yzk1In0=


# ════════════════════════════════════════════════════════════════════════════
# ANALYTICS
# ════════════════════════════════════════════════════════════════════════════
# GA4 – injected into index.html at build; used for Key events, engagement, Traffic/Landing reports (see docs/GA4-ANALYTICS-REPORT.md)
VITE_GA4_MEASUREMENT_ID=G-TJ1VXE91NE
# Microsoft Clarity (project ID in index.html; optional override for build-time)
 VITE_CLARITY_PROJECT_ID=vd7rgy7tu7
# Google AdSense (must match public/ads.txt and index.html script client)
# GOOGLE_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# ════════════════════════════════════════════════════════════════════════════
# NEWS / CONTENT PIPELINE (set in Convex Dashboard for server-side use)
# ════════════════════════════════════════════════════════════════════════════
NEWS_API_KEY=9b31770006a44e5f8889687118fa77d8
GNEWS_API_KEY=ddd458dd20c235676fa8f7cdf9142fcb
NVD_API_KEY=68ac1fd4-da27-43f5-9b4f-2acf5bec0687

# ════════════════════════════════════════════════════════════════════════════
# AUTHENTICATION (Optional) - PRODUCTION KEYS REQUIRED FOR LIVE SITE
# ════════════════════════════════════════════════════════════════════════════
# ⚠️  CRITICAL: Configure Auth0 with production keys for live deployment
# Development keys cause hydration issues, rate limiting, and auth failures on production domains
#
# STEPS TO CONFIGURE AUTH0:
# 1. Go to https://manage.auth0.com and open your application
# 2. Copy the Domain and Client ID for the SPA application
# 3. Set them in the VITE_AUTH0_* variables below
# 4. (Optional) Set the Management API audience if you use it in APIs
VITE_AUTH0_DOMAIN=dev-1hxh5m0it880xh63.us.auth0.com
VITE_AUTH0_CLIENT_ID=FGJtNX7FiMALZ863ydwbz1Z1wO6MBDjH
VITE_AUTH0_AUDIENCE=https://dev-1hxh5m0it880xh63.us.auth0.com/api/v2/

# (Deprecated) Clerk keys – no longer used after migrating to Auth0
# VITE_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# ════════════════════════════════════════════════════════════════════════════
